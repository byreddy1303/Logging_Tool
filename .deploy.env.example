# Copy this to .deploy.env (which is gitignored) and fill in every value.
# Then run scripts/deploy.sh from the repo root.

# --- Resend transactional mail -------------------------------------------
# API key from https://resend.com — free tier: 3000 mails/month.
RESEND_API_KEY=

# Sender identity. For quick testing, use 'AIR Journal <onboarding@resend.dev>'
# — this works out of the box but only sends to the Resend account owner's
# verified email. For production, verify a real domain in Resend and use
# 'AIR Journal <no-reply@yourdomain.com>'.
MAIL_FROM="AIR Journal <onboarding@resend.dev>"

# Where new /request-access notifications land.
OWNER_EMAIL=

# Absolute base URL used inside outgoing invite mails. Set after your first
# Vercel deploy to something like 'https://air-journal.vercel.app'.
VITE_APP_URL=

# --- Supabase project identity -------------------------------------------
# Get this from `supabase projects list` after `supabase login`, or from
# the URL of your project dashboard (the substring before .supabase.co).
SUPABASE_PROJECT_REF=

# --- Optional Telegram daily study digest -------------------------------
# Create the bot with @BotFather. Username is public; token stays server-side.
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=
# 1-256 characters from A-Z, a-z, 0-9, _ or -. Generate with:
#   openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
