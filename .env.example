# Client-safe (VITE_*) — shipped to browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional client-safe extras
VITE_SENTRY_DSN=
# Absolute base URL used inside invite emails ("https://your-app.vercel.app").
# When absent, edge functions fall back to the request Origin header.
VITE_APP_URL=
# Public Telegram bot username, without @. The bot token never belongs here.
VITE_TELEGRAM_BOT_USERNAME=

# Edge function only (server-side, never in client)
# Set via `supabase secrets set <key>` for deployed functions
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=

# Transactional email + access-request routing
# Resend key: https://resend.com — free tier: 3000 mails/month
RESEND_API_KEY=
# From-address on outgoing mail. Must be verified in Resend.
# Example: "AIR Journal <no-reply@yourdomain.com>"
MAIL_FROM=
# Email receiving new /request-access notifications (single owner).
OWNER_EMAIL=

# Optional Telegram daily digest (server-side only)
TELEGRAM_BOT_TOKEN=
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
