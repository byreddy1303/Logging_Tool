{
  "name": "air-journal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GATE PYQ analysis, tagging, spaced re-attempts, root-cause review, and focused buddy study. Built to compress mistake surface for AIR <100.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:native": "tsc -b && vite build --mode capacitor",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "supabase:start": "supabase start",
    "supabase:migrate": "supabase db push",
    "supabase:functions:deploy": "supabase functions deploy",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "native:sync": "npm run build:native && cap sync android",
    "android:open": "npm run native:sync && cap open android",
    "android:run": "npm run native:sync && cap run android",
    "android:apk": "npm run native:sync && cd android && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk app/build/outputs/apk/debug/airjournal.apk",
    "android:release": "npm run native:sync && cd android && ./gradlew assembleRelease && cp app/build/outputs/apk/release/app-release.apk app/build/outputs/apk/release/airjournal-release.apk",
    "android:live:release": "CAPACITOR_LIVE_SERVER_URL=https://air-journal-omega.vercel.app npm run native:sync && bash scripts/build-live-android-release.sh",
    "android:bundle": "npm run native:sync && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.2",
    "@fontsource-variable/azeret-mono": "^5.3.0",
    "@fontsource-variable/bricolage-grotesque": "^5.3.0",
    "@fontsource-variable/schibsted-grotesk": "^5.3.0",
    "@sentry/react": "^10.66.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.51.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "lucide-react": "^0.400.0",
    "motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.39",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
